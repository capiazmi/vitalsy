// BP Monitor PWA — Prisma schema
// better-auth owns: User, Session, Account, Verification (do not rename their fields).
// Domain models: BloodPressureRecord, AuditLog.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Application user. Auth handled by better-auth.
/// `role` ("admin" | "user") and ban fields come from the better-auth admin plugin.
/// NOTE: the password hash is stored on the related Account row (`Account.password`),
/// which is how better-auth models credentials.
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // better-auth admin plugin fields
  role       String?   @default("user")
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  sessions  Session[]
  accounts  Account[]
  bpRecords BloodPressureRecord[]
  auditLogs AuditLog[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  // admin plugin: set when an admin impersonates a user
  impersonatedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String? // credential hash for email/password accounts
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

/// A single blood pressure reading.
model BloodPressureRecord {
  id         String   @id @default(cuid())
  userId     String
  systolic   Int
  diastolic  Int
  pulse      Int?
  notes      String?
  recordedAt DateTime @default(now())
  imagePath  String? // key of the uploaded source image (S3), if any
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@map("blood_pressure_record")
}

/// Runtime app configuration editable by admins (e.g. OCR provider/model/keys).
/// Stored as JSON under a string key.
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("setting")
}

/// Optional audit trail for sensitive actions.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@map("audit_log")
}
