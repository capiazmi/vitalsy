# ── Database ───────────────────────────────────────────────
# Host dev with `pnpm dev` points at localhost.
# The app container in docker-compose.yml uses postgres:5432 by default.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bpmonitor?schema=public"
# Optional Docker override for the app container.
DATABASE_URL_DOCKER="postgresql://postgres:postgres@postgres:5432/bpmonitor?schema=public"

# ── App / Auth ─────────────────────────────────────────────
APP_URL=http://localhost:3000
# Generate a strong secret: pnpm dlx @better-auth/cli secret
AUTH_SECRET=change-me

# ── Seed admin (used by prisma/seed.ts on first boot) ──────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Administrator

# ── Docker compose ports ───────────────────────────────────
APP_PORT=3000
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OLLAMA_PORT=11434

# ── Postgres (docker compose) ──────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bpmonitor

# ── MinIO / free S3-compatible storage (docker compose) ────
# Console: http://localhost:9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── OCR engine (optional) ──────────────────────────────────
# AI vision OCR reads 7-segment LCDs far better than the offline fallback.
# Set ANTHROPIC_API_KEY to enable it (auto-selected when present).
ANTHROPIC_API_KEY=
# OCR_PROVIDER=anthropic | ollama | tesseract
# (default: anthropic if ANTHROPIC_API_KEY set, else ollama if configured, else tesseract)
OCR_PROVIDER=
# Model for Claude OCR (default claude-opus-4-8; claude-haiku-4-5 is cheaper)
ANTHROPIC_OCR_MODEL=claude-opus-4-8

# ── Ollama Cloud (or local) vision OCR (optional) ──────────
# Cloud: host stays ollama.com and you set an API key from ollama.com.
# Local: set OLLAMA_HOST=http://localhost:11434 (API key not needed).
OLLAMA_HOST=https://ollama.com
# Optional Docker override for the app container when using the ollama profile.
OLLAMA_HOST_DOCKER=http://ollama:11434
OLLAMA_API_KEY=
# A vision-capable model available on your Ollama account/install (e.g. qwen2.5vl, llama3.2-vision)
OLLAMA_OCR_MODEL=qwen2.5vl

# ── External S3 for OCR image storage (optional) ───────────
# For docker-compose.yml, the app container defaults to MinIO:
#   S3_ENDPOINT=http://minio:9000
#   S3_PUBLIC_URL=http://localhost:9000
# For host dev with `pnpm dev`, use http://localhost:9000.
# Leave blank to run OCR without persisting images.
S3_ENDPOINT=
# Optional Docker override for the app container.
S3_ENDPOINT_DOCKER=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=vitalsy-ocr
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=
